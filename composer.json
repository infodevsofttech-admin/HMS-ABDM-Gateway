{
    "name": "abdm/bridge-gateway",
    "description": "ABDM Bridge Gateway - PHP/CI4 Native Implementation",
    "type": "project",
    "license": "Apache-2.0",
    "homepage": "https://abdm-bridge.e-atria.in",
    "require": {
        "php": "^8.3",
        "codeigniter4/framework": "^4.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "fakerphp/faker": "^1.20"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        },
        "files": [
            "app/Common.php"
        ]
    },
    "scripts": {
        "test": "phpunit",
        "serve": "php spark serve",
        "migrate": "php spark migrate",
        "seed": "php spark db:seed"
    },
    "keywords": [
        "abdm",
        "bridge",
        "gateway",
        "healthcare",
        "fhir",
        "php",
        "codeigniter4"
    ],
    "authors": [
        {
            "name": "e-Atria Healthcare",
            "email": "dev@e-atria.in"
        }
    ]
}
