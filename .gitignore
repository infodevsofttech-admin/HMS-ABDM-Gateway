# Composer dependencies
/vendor/

# Environment files (contain credentials)
.env

# CodeIgniter writable directory – keep structure, ignore runtime files
/writable/cache/*
/writable/logs/*
/writable/session/*
/writable/uploads/*
!/writable/**/.gitkeep

# PHPUnit build output
/build/

# IDE and OS files
.idea/
.vscode/
*.DS_Store
Thumbs.db

# PHPUnit cache
.phpunit.cache/
.phpunit.result.cache
