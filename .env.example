#--------------------------------------------------------------------
# HMS-ABDM Gateway Environment Configuration
#
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'http://localhost:8080/'
# app.forceGlobalSecureRequests = false
# app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = hms_abdm_gateway
database.default.username = root
database.default.password = secret
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

# Test database
database.tests.hostname = localhost
database.tests.database = hms_abdm_gateway_test
database.tests.username = root
database.tests.password = secret
database.tests.DBDriver = MySQLi
database.tests.DBPrefix =
database.tests.charset = utf8mb4
database.tests.DBCollat = utf8mb4_general_ci
database.tests.port = 3306

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

# encryption.key = <32-char-random-key>

#--------------------------------------------------------------------
# ABDM SANDBOX
#--------------------------------------------------------------------

abdm.clientId = YOUR_ABDM_CLIENT_ID
abdm.clientSecret = YOUR_ABDM_CLIENT_SECRET
abdm.baseUrl = https://dev.abdm.gov.in
abdm.authUrl = https://dev.abdm.gov.in/api/v1/sessions

#--------------------------------------------------------------------
# NHCX
#--------------------------------------------------------------------

nhcx.baseUrl = https://api.nhcx.abdm.gov.in
nhcx.senderCode = YOUR_SENDER_CODE
nhcx.recipientCode = YOUR_RECIPIENT_CODE
nhcx.apiKey = YOUR_NHCX_API_KEY

#--------------------------------------------------------------------
# API TOKEN
#--------------------------------------------------------------------

# Secret used to sign API tokens (use a long random string)
app.apiTokenSecret = change_this_to_a_long_random_secret_value
