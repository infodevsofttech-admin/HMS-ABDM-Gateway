# HMS-ABDM Gateway — Environment Configuration
# Copy this file to `.env` and fill in the values before running the application.

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'http://localhost:8080'

#--------------------------------------------------------------------
# DATABASE
# Supported drivers: MySQLi, Postgre, SQLite3
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = hms_abdm_gateway
database.default.username = root
database.default.password = secret
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port     = 3306

#--------------------------------------------------------------------
# HMS-ABDM GATEWAY — ABDM API CONFIGURATION
#--------------------------------------------------------------------

# Environment: sandbox | production
ABDM_ENVIRONMENT = sandbox

# Base URL for the ABDM gateway API
# Sandbox : https://dev.abdm.gov.in
# Production: https://live.abdm.gov.in
ABDM_BASE_URL = https://dev.abdm.gov.in

# Credentials from the ABDM integration portal
ABDM_CLIENT_ID     = your-abdm-client-id
ABDM_CLIENT_SECRET = your-abdm-client-secret
