# ABDM Bridge Gateway - Environment Configuration
# Copy this file to .env and update values for your environment

# ==================== Application ====================

CI_ENVIRONMENT = production
APP_NAME = ABDM Bridge Gateway
APP_TIMEZONE = Asia/Kolkata

# ==================== Database ====================

database.default.hostname = localhost
database.default.database = abdm_gateway_db
database.default.username = root
database.default.password = 
database.default.DBDriver = MySQLi
database.default.DBPort = 3306
database.default.charset = utf8mb4
database.default.collation = utf8mb4_unicode_ci

# ==================== Gateway Configuration ====================

GATEWAY_SOURCE_CODE = SBXID_033661
GATEWAY_BEARER_TOKEN = 
ABDM_BRIDGE_TOKEN =
BRIDGE_SYNC_TOKEN =
GATEWAY_TEST_MODE = true
GATEWAY_PUBLIC_URL = http://127.0.0.1
GATEWAY_DEBUG_ALLOW_TOKEN_OVERRIDE = false

# ==================== ABDM API ====================

ABDM_URL = https://dev.abdm.gov.in/api/v3
ABDM_M3_URL = https://dev.abdm.gov.in/api/v3
ABDM_TOKEN =
ABDM_CLIENT_ID = SBXID_033661
ABDM_CLIENT_SECRET = YOUR_ABDM_CLIENT_SECRET
ABDM_AUTH_URL = https://dev.abdm.gov.in/gateway/v0.5/sessions
ABDM_TIMEOUT = 30

# ==================== SNOMED Service ====================

SNOMED_SERVICE_URL = https://csnotk.e-atria.in/csnoserv
SNOMED_SERVICE_TIMEOUT = 10

# ==================== Facility Configuration ====================

ABDM_HFR_ID = 
ABDM_NPI_ID = 

# ==================== Logging ====================

LOG_LEVEL = info
LOG_DATABASE = true
LOG_REQUEST_BODY = true
LOG_RESPONSE_BODY = false

# ==================== Security ====================

ENCRYPTION_KEY = 
SESSION_COOKIE_SECURE = true
SESSION_COOKIE_HTTPONLY = true

# ==================== CORS ====================

CORS_ALLOW_ORIGIN = https://e-atria.in
CORS_ALLOW_METHODS = GET,POST,OPTIONS
CORS_ALLOW_HEADERS = Content-Type,Authorization
